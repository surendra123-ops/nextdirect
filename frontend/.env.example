# Leave empty to use Vite proxy → http://localhost:5000 (backend must be running: cd backend && npm run dev)
# Or point at your deployed API (no local backend needed):
# VITE_API_BASE=https://your-service.onrender.com/api/v1
# If you use Render from localhost, set CLIENT_ORIGIN on Render to include http://localhost:5173

VITE_API_BASE=
VITE_GOOGLE_CLIENT_ID=
